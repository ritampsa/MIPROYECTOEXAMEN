title FTGO – Diagrama de contenedores (nivel 2)

Person(consumer, "Consumidor", "Usuario final que ordena comida")
Person(restaurant, "Restaurante", "Operador de cocina")
Person(courier, "Courier", "Repartidor")
Person(backoffice, "Empleado FTGO", "Back office")

System_Ext(stripe, "Stripe", "Pasarela de pago")
System_Ext(gmaps, "Google Maps", "Geocoding y rutas")
System_Ext(sendgrid, "SendGrid", "Email")
System_Ext(twilio, "Twilio", "SMS y push")
System_Ext(legacy, "Monolito Legacy", "Sistema existente")

System_Boundary(ftgo, "FTGO Platform") {
    Container(mobile_app, "Mobile App", "React Native", "App del consumidor para ordenar y trackear")
    Container(web_admin, "Web Admin", "React", "Dashboard para restaurantes, couriers y back office")

    Container(consumer_svc, "Consumer Service", "Java/Spring Boot", "Registro, perfiles, direcciones, preferencias")
    ContainerDb(consumer_db, "Consumer DB", "PostgreSQL", "Datos de consumidores")

    Container(restaurant_svc, "Restaurant Service", "Java/Spring Boot", "Menús, horarios, disponibilidad")
    ContainerDb(restaurant_db, "Restaurant DB", "PostgreSQL", "Datos de restaurantes y menús")

    Container(order_svc, "Order Service", "Java/Spring Boot", "Toma de pedidos, validación, cálculo de total")
    ContainerDb(order_db, "Order DB", "PostgreSQL", "Pedidos, ítems, estados")

    Container(kitchen_svc, "Kitchen Service", "Java/Spring Boot", "Tickets de cocina, aceptación/rechazo, tiempo preparación")
    ContainerDb(kitchen_db, "Kitchen DB", "PostgreSQL", "Tickets y estado de preparación")

    Container(delivery_svc, "Delivery Service", "Java/Spring Boot", "Asignación de couriers, rutas, tracking GPS")
    ContainerDb(delivery_db, "Delivery DB", "PostgreSQL", "Asignaciones y rutas")

    Container(billing_svc, "Billing Service", "Java/Spring Boot", "Cobros, comisiones, payouts a restaurantes y couriers")
    ContainerDb(billing_db, "Billing DB", "PostgreSQL", "Transacciones y facturación")

    Container(notification_svc, "Notification Service", "Java/Spring Boot", "Emails, SMS, push: confirmaciones, alertas, recibos")

    ContainerQueue(kafka, "Event Broker", "Apache Kafka", "Bus de eventos asíncronos entre servicios")
}

